# Clip2Post Environment Variables Configuration

# OpenAI / DeepSeek API settings
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
LLM_MODEL=""

# ASR (Automatic Speech Recognition) Model Settings
# Options: "funasr", "faster-whisper", "whisperx"
ASR_TYPE="funasr"

# FunASR Settings
ASR_MODEL_DIR="iic/speech_paraformer-large_asr_nat-zh-cn-16k-common-vocab8404-pytorch"

# Whisper / WhisperX Settings
WHISPER_MODEL_SIZE="large-v3"
# Device options: "cpu", "cuda", "mps"
WHISPER_DEVICE="cpu"
WHISPER_COMPUTE_TYPE="float32"
# 允许指定本地模型路径（如从魔塔下载到 models 目录下的路径）
# WHISPER_MODEL_PATH="models/whisper-large-v3"
WHISPER_MODEL_PATH=""

# Hugging Face Token (Required for WhisperX VAD model)
# Obtain from: https://huggingface.co/settings/tokens
HF_TOKEN=""

# Hugging Face Mirror (Optional, for region-restricted or slow connections)
# Example: https://hf-mirror.com
HF_ENDPOINT="https://hf-mirror.com"
